<style>
  .dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0 24px;
  }
  .dashboard-header h1 {
    font-size: 28px;
    font-weight: 700;
    color: #fff;
  }
  .logout-btn {
    background: none;
    border: 1px solid rgba(255,255,255,0.15);
    color: #888;
    padding: 8px 16px;
    border-radius: 10px;
    font-size: 12px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .logout-btn:hover { background: rgba(255,255,255,0.05); }

  .device-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 12px;
  }
  @media (min-width: 600px) {
    .device-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .device-card {
    background: #1c1c1e;
    border-radius: 20px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    aspect-ratio: 1;
    cursor: pointer;
    transition: background 0.15s, transform 0.1s;
    text-decoration: none;
    border: none;
  }
  .device-card:hover { background: #2c2c2e; }
  .device-card:active { transform: scale(0.97); }

  .device-label {
    font-size: 11px;
    color: #8e8e93;
    display: flex;
    align-items: center;
    gap: 5px;
    font-weight: 500;
    margin-bottom: 0;
  }

  .device-icon-area {
    flex: 1;
    display: flex;
    align-items: center;
  }

  .device-icon-wrap {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .device-icon-wrap.on {
    background: linear-gradient(135deg, #f5a623, #e8890c);
    box-shadow: 0 4px 20px rgba(245, 166, 35, 0.35);
  }
  .device-icon-wrap.off {
    background: #2c2c2e;
  }
  .device-icon-wrap.on svg { color: #fff; }
  .device-icon-wrap.off svg { color: #636366; }

  .device-bottom {
    margin-top: auto;
  }
  .device-status {
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 2px;
  }
  .device-status.on { color: #fff; }
  .device-status.off { color: #636366; }

  .device-name {
    font-size: 11px;
    color: #8e8e93;
  }

  .toggle-form { display: contents; }
  .toggle-form button {
    all: unset;
    display: contents;
    cursor: pointer;
  }
</style>

<div class="dashboard-header">
  <h1>リビング</h1>
  <%= button_to logout_path, method: :delete, class: "logout-btn" do %>
    <i data-lucide="log-out" style="width: 14px; height: 14px;"></i>
    ログアウト
  <% end %>
</div>

<div class="device-grid">
  <% @devices.each do |device| %>
    <% is_on = device[:power] == 'on' %>
    <% toggle_path = is_on ? device_off_path(device[:id]) : device_on_path(device[:id]) %>
    <%
      type = device[:type].to_s.downcase
      if type.include?('strip') || type.include?('tape')
        category = '照明'
        label_icon = 'lightbulb'
        device_icon = 'sun'
      elsif type.include?('ceiling')
        category = '照明'
        label_icon = 'lamp-ceiling'
        device_icon = 'lamp-ceiling'
      elsif type.include?('plug')
        category = 'プラグ'
        label_icon = 'plug'
        device_icon = 'power'
      elsif type.include?('curtain')
        category = 'カーテン'
        label_icon = 'blinds'
        device_icon = 'blinds'
      elsif type.include?('hub')
        category = 'ハブ'
        label_icon = 'router'
        device_icon = 'router'
      else
        category = 'デバイス'
        label_icon = 'power'
        device_icon = 'power'
      end
    %>
    <%= button_to toggle_path, method: :post, class: "toggle-form" do %>
      <div class="device-card">
        <div class="device-label">
          <i data-lucide="<%= label_icon %>" style="width: 12px; height: 12px;"></i>
          <%= category %>
        </div>

        <div class="device-icon-area">
          <div class="device-icon-wrap <%= is_on ? 'on' : 'off' %>">
            <i data-lucide="<%= device_icon %>" style="width: 30px; height: 30px;"></i>
          </div>
        </div>

        <div class="device-bottom">
          <div class="device-status <%= is_on ? 'on' : 'off' %>">
            <%= is_on ? 'ON' : 'OFF' %>
          </div>
          <div class="device-name"><%= device[:name] %></div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
