<header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; padding-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.08);">
  <div>
    <p style="font-size: 12px; color: #888; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 4px;">Home System</p>
    <h1 style="font-size: 28px; font-weight: 700; color: #fff;">Dashboard</h1>
  </div>
  <%= button_to "ログアウト", logout_path, method: :delete, class: "btn btn-secondary", style: "font-size: 12px; padding: 8px 16px;" %>
</header>

<h2 style="font-size: 20px; font-weight: 600; color: #fff; margin-bottom: 20px;">デバイス一覧</h2>

<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 16px;">
  <% @devices.each do |device| %>
    <div style="background: rgba(255,255,255,0.05); border-radius: 16px; padding: 24px; border: 1px solid rgba(255,255,255,0.08); transition: background 0.2s;">
      <div style="margin-bottom: 16px;">
        <% is_on = device[:power] == 'on' %>
        <div style="width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; margin-bottom: 12px;
          background: <%= is_on ? 'linear-gradient(135deg, #f39c12, #e67e22)' : 'rgba(255,255,255,0.08)' %>;">
          <% if device[:type]&.include?('Light') || device[:type]&.include?('light') %>
            <%= is_on ? '☀' : '☀' %>
          <% else %>
            <%= is_on ? '⚡' : '⚡' %>
          <% end %>
        </div>
        <p style="font-size: 14px; font-weight: 600; color: #fff; margin-bottom: 4px;"><%= device[:name] %></p>
        <p style="font-size: 13px; color: <%= is_on ? '#f39c12' : '#666' %>; font-weight: 600;">
          <%= is_on ? 'ON' : device[:power] == 'off' ? 'OFF' : device[:power] %>
        </p>
      </div>
      <div style="display: flex; gap: 8px;">
        <%= button_to "ON", device_on_path(device[:id]), method: :post, class: "btn btn-success", style: "flex: 1; padding: 8px; font-size: 13px; border-radius: 10px;" %>
        <%= button_to "OFF", device_off_path(device[:id]), method: :post, class: "btn btn-danger", style: "flex: 1; padding: 8px; font-size: 13px; border-radius: 10px; background: rgba(231,76,60,0.3); color: #e74c3c;" %>
      </div>
    </div>
  <% end %>
</div>
