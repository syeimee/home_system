<style>
  .bg-artwork {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .art-credit {
    position: fixed;
    top: 16px;
    left: 20px;
    z-index: 1;
    font-size: 11px;
    color: rgba(255,255,255,0.6);
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
  }
  .art-credit .art-title {
    font-weight: 700;
    font-size: 13px;
    margin-bottom: 2px;
  }

  .drawer {
    position: fixed;
    left: 0; right: 0; bottom: 0;
    top: 56px;
    z-index: 10;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 20px 20px 0 0;
    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
    overflow-y: auto;
    padding: 0 36px 20px;
  }
  .drawer.collapsed {
    transform: translateY(calc(100% - 28px));
  }
  .drawer.collapsed .drawer-title,
  .drawer.collapsed .device-grid {
    opacity: 0;
    pointer-events: none;
  }

  .drawer-handle-area {
    position: sticky;
    top: 0;
    background: transparent;
    padding: 10px 0 10px;
    cursor: pointer;
    z-index: 11;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .drawer-handle {
    width: 36px;
    height: 5px;
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.3);
    margin-bottom: 10px;
  }

  .drawer-title {
    font-size: 22px;
    font-weight: 700;
    color: #fff;
    width: 100%;
    transition: opacity 0.2s;
  }

  .device-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    padding-top: 4px;
    transition: opacity 0.2s;
  }
  @media (max-width: 480px) {
    .device-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .device-card {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 16px;
    padding: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    aspect-ratio: 1;
    cursor: pointer;
    transition: background 0.15s, transform 0.1s;
    text-decoration: none;
  }
  .device-card:hover { background: rgba(255, 255, 255, 0.1); }
  .device-card:active { transform: scale(0.96); }

  .device-label {
    font-size: 10px;
    color: rgba(255,255,255,0.4);
    display: flex;
    align-items: center;
    gap: 4px;
    font-weight: 500;
    align-self: flex-start;
  }

  .device-icon-area {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .device-icon-wrap {
    width: 46px;
    height: 46px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .device-icon-wrap.on {
    background: linear-gradient(135deg, #f5a623, #e8890c);
    box-shadow: 0 4px 16px rgba(245, 166, 35, 0.35);
  }
  .device-icon-wrap.off {
    background: rgba(255, 255, 255, 0.04);
  }
  .device-icon-wrap.on svg { color: #fff; }
  .device-icon-wrap.off svg { color: rgba(255,255,255,0.15); }

  .device-name {
    font-size: 10px;
    color: rgba(255,255,255,0.45);
    margin-top: 4px;
    text-align: center;
  }

  .toggle-form { display: none !important; }

  .device-card.loading {
    opacity: 0.5;
    pointer-events: none;
  }
</style>

<% content_for :navbar do %>
  <nav class="navbar">
    <%= button_to logout_path, method: :delete, class: "navbar-icon-btn", data: { turbo: false } do %>
      <i data-lucide="log-out" style="width: 18px; height: 18px;"></i>
    <% end %>
  </nav>
<% end %>

<% if @artwork %>
  <div class="bg-artwork" style="background-image: url('<%= @artwork[:image_url] %>');"></div>
  <div class="art-credit">
    <div class="art-title"><%= @artwork[:title] %></div>
    <div><%= @artwork[:artist] %><%= " (#{@artwork[:date]})" if @artwork[:date].present? %></div>
  </div>
<% end %>

<div class="drawer" id="drawer">
  <div class="drawer-handle-area" id="drawerHandle">
    <div class="drawer-handle"></div>
    <div class="drawer-title">リビング</div>
  </div>

  <div class="device-grid">
    <% @devices.each do |device| %>
      <% is_on = device[:power] == 'on' %>
      <% toggle_path = is_on ? device_off_path(device[:id]) : device_on_path(device[:id]) %>
      <%
        type = device[:type].to_s.downcase
        if type.include?('strip') || type.include?('tape')
          category = '照明'
          label_icon = 'lightbulb'
          device_icon = 'sun'
        elsif type.include?('ceiling')
          category = '照明'
          label_icon = 'lamp-ceiling'
          device_icon = 'lamp-ceiling'
        elsif type.include?('plug')
          category = 'プラグ'
          label_icon = 'plug'
          device_icon = 'power'
        elsif type.include?('curtain')
          category = 'カーテン'
          label_icon = 'blinds'
          device_icon = 'blinds'
        elsif type.include?('hub')
          category = 'ハブ'
          label_icon = 'router'
          device_icon = 'router'
        else
          category = 'デバイス'
          label_icon = 'power'
          device_icon = 'power'
        end
      %>
      <div class="device-card" data-on-url="<%= device_on_path(device[:id]) %>" data-off-url="<%= device_off_path(device[:id]) %>" data-state="<%= is_on ? 'on' : 'off' %>" onclick="toggleDevice(this)">
        <div class="device-label">
          <i data-lucide="<%= label_icon %>" style="width: 10px; height: 10px;"></i>
          <%= category %>
        </div>

        <div class="device-icon-area">
          <div class="device-icon-wrap <%= is_on ? 'on' : 'off' %>">
            <i data-lucide="<%= device_icon %>" style="width: 32px; height: 32px;"></i>
          </div>
        </div>

        <div class="device-name"><%= device[:name] %></div>
      </div>
    <% end %>
  </div>
</div>

<script>
  const csrfToken = document.querySelector('meta[name="csrf-token"]').content;

  function toggleDevice(card) {
    if (card.classList.contains('loading')) return;

    const isOn = card.dataset.state === 'on';
    const url = isOn ? card.dataset.offUrl : card.dataset.onUrl;
    const newState = isOn ? 'off' : 'on';

    // 即座に見た目を切り替え
    card.dataset.state = newState;
    const iconWrap = card.querySelector('.device-icon-wrap');
    iconWrap.classList.remove('on', 'off');
    iconWrap.classList.add(newState);

    card.classList.add('loading');

    fetch(url, {
      method: 'POST',
      headers: {
        'X-CSRF-Token': csrfToken,
        'Accept': 'text/html'
      }
    }).then(() => {
      card.classList.remove('loading');
    }).catch(() => {
      // 失敗したら元に戻す
      card.dataset.state = isOn ? 'on' : 'off';
      iconWrap.classList.remove('on', 'off');
      iconWrap.classList.add(isOn ? 'on' : 'off');
      card.classList.remove('loading');
    });
  }

  const drawer = document.getElementById('drawer');
  const handle = document.getElementById('drawerHandle');

  handle.addEventListener('click', () => {
    drawer.classList.toggle('collapsed');
  });

  let startY = 0;
  let dragging = false;

  drawer.addEventListener('touchstart', (e) => {
    if (e.target.closest('.device-card')) return;
    startY = e.touches[0].clientY;
    dragging = true;
  });

  drawer.addEventListener('touchend', (e) => {
    if (!dragging) return;
    dragging = false;
    const diff = e.changedTouches[0].clientY - startY;
    if (diff > 60) {
      drawer.classList.add('collapsed');
    } else if (diff < -60) {
      drawer.classList.remove('collapsed');
    }
  });
</script>
