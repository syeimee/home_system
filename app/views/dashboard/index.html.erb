<style>
  .dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0 24px;
  }
  .dashboard-header h1 {
    font-size: 28px;
    font-weight: 700;
    color: #fff;
  }
  .logout-btn {
    background: none;
    border: 1px solid rgba(255,255,255,0.15);
    color: #888;
    padding: 8px 16px;
    border-radius: 10px;
    font-size: 12px;
    cursor: pointer;
  }
  .logout-btn:hover { background: rgba(255,255,255,0.05); }

  .device-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 12px;
  }
  @media (min-width: 600px) {
    .device-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .device-card {
    background: #1c1c1e;
    border-radius: 20px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    aspect-ratio: 1;
    position: relative;
    cursor: pointer;
    transition: background 0.2s;
  }
  .device-card:hover { background: #2c2c2e; }

  .device-label {
    font-size: 11px;
    color: #8e8e93;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .device-label .icon { font-size: 10px; }

  .device-icon-wrap {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: auto auto 8px 0;
  }
  .device-icon-wrap.on {
    background: linear-gradient(135deg, #f5a623, #f7931e);
  }
  .device-icon-wrap.off {
    background: #2c2c2e;
  }
  .device-icon {
    font-size: 28px;
    filter: drop-shadow(0 1px 2px rgba(0,0,0,0.3));
  }

  .device-status {
    font-size: 14px;
    font-weight: 600;
    color: #fff;
    margin-top: auto;
  }
  .device-name {
    font-size: 12px;
    color: #8e8e93;
    margin-top: 2px;
  }

  .device-actions {
    display: flex;
    gap: 6px;
    margin-top: 10px;
  }
  .device-actions form { flex: 1; display: flex; }
  .device-actions button {
    flex: 1;
    padding: 8px 0;
    border: none;
    border-radius: 10px;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .device-actions button:hover { opacity: 0.8; }
  .btn-on {
    background: linear-gradient(135deg, #f5a623, #f7931e);
    color: #fff;
  }
  .btn-off {
    background: rgba(255,255,255,0.08);
    color: #8e8e93;
  }
</style>

<div class="dashboard-header">
  <h1>リビング</h1>
  <%= button_to "ログアウト", logout_path, method: :delete, class: "logout-btn" %>
</div>

<div class="device-grid">
  <% @devices.each do |device| %>
    <% is_on = device[:power] == 'on' %>
    <% is_light = device[:type].to_s.downcase.include?('light') %>
    <div class="device-card">
      <div class="device-label">
        <span class="icon"><%= is_light ? '💡' : '⚡' %></span>
        <%= is_light ? '照明' : 'デバイス' %>
      </div>

      <div class="device-icon-wrap <%= is_on ? 'on' : 'off' %>">
        <span class="device-icon"><%= is_on ? '☀' : '☀' %></span>
      </div>

      <div class="device-status"><%= is_on ? 'ON' : 'OFF' %></div>
      <div class="device-name"><%= device[:name] %></div>

      <div class="device-actions">
        <%= button_to "ON", device_on_path(device[:id]), method: :post, class: "btn-on" %>
        <%= button_to "OFF", device_off_path(device[:id]), method: :post, class: "btn-off" %>
      </div>
    </div>
  <% end %>
</div>
