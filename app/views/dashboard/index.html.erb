<style>
  .bg-artwork {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .clock {
    position: fixed;
    bottom: 120px;
    left: 48px;
    z-index: 5;
    color: rgba(255,255,255,0.5);
    text-shadow: 0 1px 3px rgba(0,0,0,0.5);
  }
  .clock-time {
    font-size: 144px;
    font-weight: 200;
    letter-spacing: 6px;
    line-height: 1;
  }
  .clock-date {
    font-size: 28px;
    opacity: 0.7;
    margin-top: 12px;
    letter-spacing: 2px;
  }

  .art-credit {
    position: fixed;
    bottom: 12px;
    right: 16px;
    z-index: 5;
    font-size: 10px;
    color: rgba(255,255,255,0.35);
    text-align: right;
    text-shadow: 0 1px 3px rgba(0,0,0,0.5);
  }
  .art-credit .art-title {
    font-weight: 600;
    font-size: 10px;
    margin-bottom: 1px;
  }

  .calendar-panel {
    position: fixed;
    top: 80px;
    right: 24px;
    z-index: 5;
    width: 280px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    color: rgba(255,255,255,0.7);
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 20px;
    padding: 20px;
  }
  .calendar-panel::-webkit-scrollbar { display: none; }
  .calendar-day-label {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.4);
    letter-spacing: 1px;
    margin-bottom: 8px;
    margin-top: 16px;
  }
  .calendar-day-label:first-child { margin-top: 0; }
  .calendar-event {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .calendar-event:last-child { border-bottom: none; }
  .calendar-event-time {
    font-size: 13px;
    font-weight: 500;
    color: rgba(255,255,255,0.4);
    min-width: 48px;
    flex-shrink: 0;
  }
  .calendar-event-title {
    font-size: 14px;
    font-weight: 400;
    color: rgba(255,255,255,0.7);
    line-height: 1.4;
  }
  .calendar-event-interview .calendar-event-title {
    color: #f5a623;
  }

  .drawer {
    position: fixed;
    left: 0; right: 0; bottom: 0;
    top: 56px;
    z-index: 10;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 20px 20px 0 0;
    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
    overflow-y: auto;
    padding: 0 40px 20px;
  }
  .drawer.collapsed {
    transform: translateY(calc(100% - 28px));
  }
  .drawer.collapsed .drawer-title,
  .drawer.collapsed .device-grid {
    opacity: 0;
    pointer-events: none;
  }

  .drawer-handle-area {
    position: sticky;
    top: 0;
    background: transparent;
    padding: 10px 0 10px;
    cursor: pointer;
    z-index: 11;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .drawer-handle {
    width: 36px;
    height: 5px;
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.3);
    margin-bottom: 10px;
  }

  .drawer-title {
    font-size: 22px;
    font-weight: 700;
    color: #fff;
    width: 100%;
    transition: opacity 0.2s;
  }

  .device-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    padding-top: 8px;
    transition: opacity 0.2s;
  }
  @media (max-width: 480px) {
    .device-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .device-card {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 20px;
    padding: 14px;
    display: flex;
    flex-direction: column;
    aspect-ratio: 1;
    cursor: pointer;
    transition: background 0.15s, transform 0.1s;
    text-decoration: none;
  }
  .device-card:hover { background: rgba(255, 255, 255, 0.1); }
  .device-card:active { transform: scale(0.96); }

  .device-label {
    font-size: 11px;
    color: rgba(255,255,255,0.5);
    display: flex;
    align-items: center;
    gap: 4px;
    font-weight: 500;
  }

  .device-icon-area {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .device-icon-wrap {
    width: 75%;
    aspect-ratio: 1;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .device-icon-wrap.on {
    background: linear-gradient(135deg, #f5a623, #e8890c);
    box-shadow: 0 6px 20px rgba(245, 166, 35, 0.4);
  }
  .device-icon-wrap.off {
    background: rgba(255, 255, 255, 0.05);
  }
  .device-icon-wrap.on svg { color: #fff; }
  .device-icon-wrap.off svg { color: rgba(255,255,255,0.2); }

  .device-name {
    font-size: 11px;
    color: rgba(255,255,255,0.5);
    margin-top: 6px;
    text-align: center;
  }

  .toggle-form { display: none !important; }

  .calendar-panel.hidden { display: none; }

  .device-card.loading {
    opacity: 0.5;
    pointer-events: none;
  }
</style>

<% content_for :navbar do %>
  <nav class="navbar">
    <button class="navbar-icon-btn" onclick="toggleCalendar()" id="calendarBtn">
      <i data-lucide="calendar" style="width: 18px; height: 18px;"></i>
    </button>
    <button class="navbar-icon-btn" onclick="toggleFullscreen()" id="fullscreenBtn">
      <i data-lucide="maximize" style="width: 18px; height: 18px;"></i>
    </button>
    <%= button_to logout_path, method: :delete, class: "navbar-icon-btn", data: { turbo: false } do %>
      <i data-lucide="log-out" style="width: 18px; height: 18px;"></i>
    <% end %>
  </nav>
<% end %>

<div class="clock">
  <div class="clock-time" id="clockTime"></div>
  <div class="clock-date" id="clockDate"></div>
</div>

<% if @artwork %>
  <div class="bg-artwork" style="background-image: url('<%= @artwork[:image_url] %>');"></div>
  <div class="art-credit">
    <div class="art-title"><%= @artwork[:title] %></div>
    <div><%= @artwork[:artist] %><%= " (#{@artwork[:date]})" if @artwork[:date].present? %></div>
  </div>
<% end %>

<% if @events.present? %>
  <div class="calendar-panel">
    <%
      today = Time.current.in_time_zone.to_date
      tomorrow = today + 1
      today_events = @events.select { |e| e[:start_time].to_date == today }
      tomorrow_events = @events.select { |e| e[:start_time].to_date == tomorrow }
      interview_keywords = Settings[:interview][:keywords].map(&:downcase)
    %>
    <% if today_events.any? %>
      <div class="calendar-day-label">TODAY</div>
      <% today_events.each do |event| %>
        <% is_interview = interview_keywords.any? { |kw| event[:subject].to_s.downcase.include?(kw) } %>
        <div class="calendar-event <%= 'calendar-event-interview' if is_interview %>">
          <div class="calendar-event-time"><%= event[:all_day] ? '終日' : event[:start_time].strftime('%H:%M') %></div>
          <div class="calendar-event-title"><%= event[:subject] %></div>
        </div>
      <% end %>
    <% end %>
    <% if tomorrow_events.any? %>
      <div class="calendar-day-label">TOMORROW</div>
      <% tomorrow_events.each do |event| %>
        <% is_interview = interview_keywords.any? { |kw| event[:subject].to_s.downcase.include?(kw) } %>
        <div class="calendar-event <%= 'calendar-event-interview' if is_interview %>">
          <div class="calendar-event-time"><%= event[:all_day] ? '終日' : event[:start_time].strftime('%H:%M') %></div>
          <div class="calendar-event-title"><%= event[:subject] %></div>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>

<div class="drawer" id="drawer">
  <div class="drawer-handle-area" id="drawerHandle">
    <div class="drawer-handle"></div>
    <div class="drawer-title">リビング</div>
  </div>

  <div class="device-grid">
    <% @devices.each do |device| %>
      <% is_on = device[:power] == 'on' %>
      <% toggle_path = is_on ? device_off_path(device[:id]) : device_on_path(device[:id]) %>
      <%
        type = device[:type].to_s.downcase
        if type.include?('strip') || type.include?('tape')
          category = '照明'
          label_icon = 'lightbulb'
          device_icon = 'sun'
        elsif type.include?('ceiling')
          category = '照明'
          label_icon = 'lamp-ceiling'
          device_icon = 'lamp-ceiling'
        elsif type.include?('plug')
          category = 'プラグ'
          label_icon = 'plug'
          device_icon = 'power'
        elsif type.include?('curtain')
          category = 'カーテン'
          label_icon = 'blinds'
          device_icon = 'blinds'
        elsif type.include?('hub')
          category = 'ハブ'
          label_icon = 'router'
          device_icon = 'router'
        else
          category = 'デバイス'
          label_icon = 'power'
          device_icon = 'power'
        end
      %>
      <div class="device-card" data-device-id="<%= device[:id] %>" data-on-url="<%= device_on_path(device[:id]) %>" data-off-url="<%= device_off_path(device[:id]) %>" data-state="<%= is_on ? 'on' : 'off' %>" onclick="toggleDevice(this)">
        <div class="device-label">
          <i data-lucide="<%= label_icon %>" style="width: 10px; height: 10px;"></i>
          <%= category %>
        </div>

        <div class="device-icon-area">
          <div class="device-icon-wrap <%= is_on ? 'on' : 'off' %>">
            <i data-lucide="<%= device_icon %>" style="width: 50%; height: 50%;"></i>
          </div>
        </div>

        <div class="device-name"><%= device[:name] %></div>
      </div>
    <% end %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@rails/actioncable/app/assets/javascripts/actioncable.js"></script>
<script>
  (function() {
    var csrfToken = document.querySelector('meta[name="csrf-token"]').content;

    // WebSocket 接続
    var cable = ActionCable.createConsumer('/cable');
    cable.subscriptions.create('DeviceStatusChannel', {
      received: function(data) {
        var card = document.querySelector('[data-device-id="' + data.deviceId + '"]');
        if (!card) return;

        var state = data.power === 'on' ? 'on' : 'off';
        card.dataset.state = state;
        var iconWrap = card.querySelector('.device-icon-wrap');
        iconWrap.classList.remove('on', 'off');
        iconWrap.classList.add(state);
        card.classList.remove('loading');
      }
    });

    // カードタップでコマンド送信（楽観的更新）
    window.toggleDevice = function(card) {
      if (card.classList.contains('loading')) return;

      var isOn = card.dataset.state === 'on';
      var url = isOn ? card.dataset.offUrl : card.dataset.onUrl;
      var newState = isOn ? 'off' : 'on';

      card.dataset.state = newState;
      var iconWrap = card.querySelector('.device-icon-wrap');
      iconWrap.classList.remove('on', 'off');
      iconWrap.classList.add(newState);
      card.classList.add('loading');

      fetch(url, {
        method: 'POST',
        headers: { 'X-CSRF-Token': csrfToken, 'Accept': 'application/json' }
      }).then(function() {
        card.classList.remove('loading');
      }).catch(function() {
        card.dataset.state = isOn ? 'on' : 'off';
        iconWrap.classList.remove('on', 'off');
        iconWrap.classList.add(isOn ? 'on' : 'off');
        card.classList.remove('loading');
      });
    };

    // カレンダー表示切替
    window.toggleCalendar = function() {
      var panel = document.querySelector('.calendar-panel');
      if (panel) panel.classList.toggle('hidden');
    };

    // フルスクリーン
    window.toggleFullscreen = function() {
      if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen().catch(function() {});
      } else {
        document.exitFullscreen();
      }
    };
    document.addEventListener('fullscreenchange', function() {
      var btn = document.getElementById('fullscreenBtn');
      var icon = btn.querySelector('i');
      icon.setAttribute('data-lucide', document.fullscreenElement ? 'minimize' : 'maximize');
      lucide.createIcons();
    });

    // 無音再生（フルスクリーン時のみ、Echo Show スリープ防止）
    var silenceAudio = null;
    var wakeLock = null;

    function startSilence() {
      if (!silenceAudio) {
        silenceAudio = new Audio('/silence.mp3');
        silenceAudio.loop = true;
        silenceAudio.volume = 0.01;
      }
      silenceAudio.play().catch(function() {});
      if (navigator.wakeLock) {
        navigator.wakeLock.request('screen').then(function(lock) {
          wakeLock = lock;
        }).catch(function() {});
      }
    }

    function stopSilence() {
      if (silenceAudio) { silenceAudio.pause(); }
      if (wakeLock) { wakeLock.release(); wakeLock = null; }
    }

    document.addEventListener('fullscreenchange', function() {
      if (document.fullscreenElement) {
        startSilence();
      } else {
        stopSilence();
      }
    });

    // アートワーク定期更新（15分ごと）
    var currentImageUrl = '<%= @artwork&.dig(:image_url) %>';
    setInterval(function() {
      fetch('/dashboard/artwork', {
        headers: { 'Accept': 'application/json' }
      }).then(function(res) { return res.json(); })
        .then(function(data) {
          if (!data.image_url || data.image_url === currentImageUrl) return;
          currentImageUrl = data.image_url;
          var bg = document.querySelector('.bg-artwork');
          if (bg) bg.style.backgroundImage = "url('" + data.image_url + "')";
          var titleEl = document.querySelector('.art-credit .art-title');
          if (titleEl) titleEl.textContent = data.title || '';
          var creditEl = document.querySelector('.art-credit .art-title + div');
          if (creditEl) {
            var text = data.artist || '';
            if (data.date) text += ' (' + data.date + ')';
            creditEl.textContent = text;
          }
        }).catch(function() {});
    }, 15 * 60 * 1000);

    // 時計
    function updateClock() {
      var now = new Date();
      var h = String(now.getHours()).padStart(2, '0');
      var m = String(now.getMinutes()).padStart(2, '0');
      document.getElementById('clockTime').textContent = h + ':' + m;

      var days = ['日', '月', '火', '水', '木', '金', '土'];
      var y = now.getFullYear();
      var mo = now.getMonth() + 1;
      var d = now.getDate();
      var day = days[now.getDay()];
      document.getElementById('clockDate').textContent = y + '/' + mo + '/' + d + ' (' + day + ')';
    }
    updateClock();
    setInterval(updateClock, 10000);

    // ドロワー
    var drawer = document.getElementById('drawer');
    var handle = document.getElementById('drawerHandle');

    handle.addEventListener('click', function() {
      drawer.classList.toggle('collapsed');
    });

    var startY = 0;
    var dragging = false;

    drawer.addEventListener('touchstart', function(e) {
      if (e.target.closest('.device-card')) return;
      startY = e.touches[0].clientY;
      dragging = true;
    });

    drawer.addEventListener('touchend', function(e) {
      if (!dragging) return;
      dragging = false;
      var diff = e.changedTouches[0].clientY - startY;
      if (diff > 60) {
        drawer.classList.add('collapsed');
      } else if (diff < -60) {
        drawer.classList.remove('collapsed');
      }
    });
  })();
</script>
