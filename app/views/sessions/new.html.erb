<style>
  .login-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 80vh;
  }
  .login-title {
    font-size: 32px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 8px;
  }
  .login-sub {
    font-size: 13px;
    color: #8e8e93;
    margin-bottom: 48px;
  }
  .login-btn {
    background: linear-gradient(135deg, #4285f4, #356ac3);
    color: #fff;
    border: none;
    padding: 16px 40px;
    border-radius: 16px;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .login-btn:hover { opacity: 0.85; }
</style>

<div class="login-wrap">
  <h1 class="login-title">Home System</h1>
  <p class="login-sub">ログインして続行</p>
  <%= button_to "Googleでログイン", "/auth/google_oauth2", method: :post, class: "login-btn", data: { turbo: false } %>
</div>
