<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>Home System</title>
  <link rel="icon" href="/favicon.ico">
  <link rel="icon" href="/logo.svg" type="image/svg+xml">
  <%= csrf_meta_tags %>
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Hiragino Sans", "Segoe UI", Roboto, sans-serif;
      background: #000;
      color: #fff;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }
    .logo {
      position: fixed;
      top: 16px;
      left: 20px;
      z-index: 20;
      width: 36px;
      height: 36px;
      border-radius: 8px;
      opacity: 0.7;
    }
    .navbar {
      position: fixed;
      top: 16px;
      right: 16px;
      z-index: 20;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .navbar-icon-btn {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: rgba(0, 0, 0, 0.3);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: none;
      color: rgba(255,255,255,0.7);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .navbar-icon-btn:hover { background: rgba(0, 0, 0, 0.5); }

    .alert {
      position: fixed;
      top: 52px;
      left: 16px; right: 16px;
      z-index: 21;
      padding: 10px 16px;
      border-radius: 12px;
      font-size: 13px;
      backdrop-filter: blur(20px);
    }
    .alert-notice { background: rgba(40, 167, 69, 0.2); color: #6fcf87; }
    .alert-alert { background: rgba(220, 53, 69, 0.2); color: #f08090; }
  </style>
</head>
<body>
  <img src="/logo.svg" alt="Home System" class="logo">
  <% if content_for?(:navbar) %>
    <%= yield(:navbar) %>
  <% end %>
  <% if notice %>
    <div class="alert alert-notice"><%= notice %></div>
  <% end %>
  <% if alert %>
    <div class="alert alert-alert"><%= alert %></div>
  <% end %>
  <%= yield %>
  <script>lucide.createIcons();</script>
</body>
</html>
