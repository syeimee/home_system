<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>Home System</title>
  <%= csrf_meta_tags %>
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Hiragino Sans", "Segoe UI", Roboto, sans-serif;
      background: #000;
      color: #fff;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }
    .navbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 20;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 20px;
      background: rgba(0, 0, 0, 0.4);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
    }
    .navbar-brand {
      font-size: 14px;
      font-weight: 700;
      color: #fff;
      letter-spacing: 0.5px;
    }
    .navbar-actions {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .navbar-btn {
      background: rgba(255,255,255,0.1);
      border: none;
      color: rgba(255,255,255,0.6);
      padding: 6px 12px;
      border-radius: 8px;
      font-size: 11px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .navbar-btn:hover { background: rgba(255,255,255,0.15); }

    .alert {
      position: fixed;
      top: 52px;
      left: 16px; right: 16px;
      z-index: 21;
      padding: 10px 16px;
      border-radius: 12px;
      font-size: 13px;
      backdrop-filter: blur(20px);
    }
    .alert-notice { background: rgba(40, 167, 69, 0.2); color: #6fcf87; }
    .alert-alert { background: rgba(220, 53, 69, 0.2); color: #f08090; }
  </style>
</head>
<body>
  <% if content_for?(:navbar) %>
    <%= yield(:navbar) %>
  <% end %>
  <% if notice %>
    <div class="alert alert-notice"><%= notice %></div>
  <% end %>
  <% if alert %>
    <div class="alert alert-alert"><%= alert %></div>
  <% end %>
  <%= yield %>
  <script>lucide.createIcons();</script>
</body>
</html>
