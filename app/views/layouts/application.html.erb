<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home System</title>
  <%= csrf_meta_tags %>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #1a1a2e;
      color: #e0e0e0;
      min-height: 100vh;
    }
    .container { max-width: 960px; margin: 0 auto; padding: 24px; }
    .alert {
      padding: 12px 16px;
      border-radius: 12px;
      margin-bottom: 16px;
      font-size: 14px;
    }
    .alert-notice { background: rgba(40, 167, 69, 0.2); color: #6fcf87; border: 1px solid rgba(40, 167, 69, 0.3); }
    .alert-alert { background: rgba(220, 53, 69, 0.2); color: #f08090; border: 1px solid rgba(220, 53, 69, 0.3); }
    .btn {
      display: inline-block;
      padding: 10px 20px;
      border: none;
      border-radius: 12px;
      cursor: pointer;
      text-decoration: none;
      font-size: 14px;
      font-weight: 600;
      transition: transform 0.1s, opacity 0.2s;
    }
    .btn:hover { opacity: 0.85; }
    .btn:active { transform: scale(0.96); }
    .btn-primary { background: #4285f4; color: #fff; }
    .btn-danger { background: #e74c3c; color: #fff; }
    .btn-success { background: #f39c12; color: #fff; }
    .btn-secondary { background: rgba(255,255,255,0.1); color: #aaa; }
  </style>
</head>
<body>
  <div class="container">
    <% if notice %>
      <div class="alert alert-notice"><%= notice %></div>
    <% end %>
    <% if alert %>
      <div class="alert alert-alert"><%= alert %></div>
    <% end %>
    <%= yield %>
  </div>
</body>
</html>
