<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>Home System</title>
  <%= csrf_meta_tags %>
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Hiragino Sans", "Segoe UI", Roboto, sans-serif;
      background: #000;
      color: #fff;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }
    .container { max-width: 960px; margin: 0 auto; padding: 20px 16px; }
    .alert {
      padding: 12px 16px;
      border-radius: 14px;
      margin-bottom: 16px;
      font-size: 13px;
      backdrop-filter: blur(20px);
    }
    .alert-notice { background: rgba(40, 167, 69, 0.2); color: #6fcf87; }
    .alert-alert { background: rgba(220, 53, 69, 0.2); color: #f08090; }
  </style>
</head>
<body>
  <% if notice %>
    <div class="container"><div class="alert alert-notice"><%= notice %></div></div>
  <% end %>
  <% if alert %>
    <div class="container"><div class="alert alert-alert"><%= alert %></div></div>
  <% end %>
  <%= yield %>
  <script>lucide.createIcons();</script>
</body>
</html>
